<odoo>
    <data>

        <record id="form_cancel_appointment_wizard" model="ir.ui.view">
            <field name="name">hospital cancel appointment wizard</field>
            <field name="model">hospital.cancel.appointment.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>

                        <group>
                            <field name="name"/>

                            <field name="appointment_id"/>
                            <field name="reason"/>
                        </group>
                        <footer>
                            <button name="save" string="save" type="object" class="btn btn-success"/>
                            <button special="cancel" string="cancel" type="cancel" class="btn btn-danger"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>


        <record id="action_cancel_appointment_wizard" model="ir.actions.act_window">
            <field name="name">action cancel appointment wizard</field>
            <field name="res_model">hospital.cancel.appointment.wizard</field>
            <field name="target">new</field>
            <field name="view_mode">form</field>
        </record>
    </data>
</odoo>