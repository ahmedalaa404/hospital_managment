<odoo>

    <record id="view_hospital_appointments_list" model="ir.ui.view">
        <field name="name">view of hospital appointments list</field>
        <field name="model">hospital.appointments</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="patient_id"/>
                <field name="gender"/>

                <field name="appointment_time"/>
                <field name="booking_date"/>
            </tree>
        </field>
    </record>


    <record id="view_hospital_appointments_form" model="ir.ui.view">
        <field name="name">view of hospital appointments form</field>
        <field name="model">hospital.appointments</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="patient_id"/>
                        <field name="gender"/>
                        <field name="appointment_time"/>
                        <field name="booking_date"/>
                    </group>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>


            </form>
        </field>
    </record>


    <record id="actions_hospital_appointments" model="ir.actions.act_window">
        <field name="name">hospital</field>
        <field name="res_model">hospital.appointments</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_filter_with_gender_male':1}</field>
        <field name="help" type="html">
            <div class="text-warning">
                <p>
                    not have any appointments her can make register new appointments
                </p>
            </div>
        </field>
    </record>

    <menuitem id="appointments_menu_item"
              parent="mnu_appointments_item"
              name="appointments"
              action="actions_hospital_appointments"/>
</odoo>