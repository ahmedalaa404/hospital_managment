<odoo>

    <record id="view_hospital_appointments_list" model="ir.ui.view">
        <field name="name">view of hospital appointments list</field>
        <field name="model">hospital.appointments</field>
        <field name="arch" type="xml">
            <tree multi_edit="1" sample="1">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="gender"/>
                <!--               not open in chat allow to send message -->

                <field name="doctor_id" widget="many2one_avatar"/>

                <!--                open in chat allow to send message -->
                <field name="doctor_id" widget="many2one_avatar_user"/>


                <field name="appointment_time"/>
                <field name="booking_date"/>
                <field name="activity_ids" widget="list_activity"/>
            </tree>
        </field>
    </record>


    <record id="view_hospital_appointments_form" model="ir.ui.view">
        <field name="name">view of hospital appointments form</field>
        <field name="model">hospital.appointments</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar" options="{'clickable':true}"/>

                    <button data-hotkey="v" type="object" name="set_draft" string="draft"/>
                    <button data-hotkey="p" type="object" name="set_in_process" string="process"/>
                    <button data-hotkey="d" type="object" name="set_done" string="Done"/>
                    <button data-hotkey="c" type="object" name="set_cancel" string="cancel"/>
                    <field name="priority" widget="priority"/>

                </header>
                <sheet>
                    <group>

                        <field name="name"/>
                        <field name="patient_id"/>
                        <field name="gender"/>
                        <field name="appointment_time"/>
                        <field name="doctor_id" widget="many2one_avatar"/>
                        <field name="booking_date"/>

                        <button name="action_test" string="test rainbow" type="object"/>
                    </group>

                    <notebook>
                        <page string="prescription" name="prescription">
                            <group>
                                <field name="appointment_time"/>
                            </group>
                            <notebook>
                                <page string="pharmacy" name="pharmacy">
                                    <group>
                                        <field name="hospital_appointments_pharmacy_lines_ids">
<!--                                            <tree>-->
<!--                                                <field name="name"/>-->
<!--                                                <field name="product_id"/>-->
<!--                                                <field name="qty"/>-->
<!--                                                <field name="price_unite"/>-->
<!--                                            </tree>-->

<!--                                            <form>-->
<!--                                                <field name="name"/>-->
<!--                                                <field name="product_id"/>-->
<!--                                                <field name="qty"/>-->
<!--                                                <field name="price_unite"/>-->
<!--                                            </form>-->

                                        </field>

                                    </group>
                                </page>
                            </notebook>
                        </page>
                    </notebook>

                    <notebook>
                        <page string="prescription" name="patients">
                            <field name="gender"/>

                        </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>


            </form>
        </field>
    </record>


    <record id="actions_hospital_appointments" model="ir.actions.act_window">
        <field name="name">hospital</field>
        <field name="res_model">hospital.appointments</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_filter_with_gender_male':1}</field>
        <field name="help" type="html">
            <div class="text-warning">
                <p>
                    not have any appointments her can make register new appointments
                </p>
            </div>
        </field>
    </record>

    <menuitem id="appointments_menu_item"
              parent="mnu_appointments_item"
              name="appointments"
              action="actions_hospital_appointments"/>
</odoo>