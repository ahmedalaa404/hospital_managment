<odoo>

    <record id="view_hospital_appointments_list" model="ir.ui.view">
        <field name="name">view of hospital appointments list</field>
        <field name="model">hospital.appointments</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>


    <record id="view_hospital_appointments_form" model="ir.ui.view">
        <field name="name">view of hospital appointments form</field>
        <field name="model">hospital.appointments</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>

                <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                </div>


            </form>
        </field>
    </record>


    <record id="view_hospital_appointments_search" model="ir.ui.view">
        <field name="name">view of hospital appointments search</field>
        <field name="model">hospital.appointments</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" filter_domain="['|',('name','ilike',self),('ref','ilike',self)]"
                       string="search with name "/>
                <field name="name" string="appointments name"/>
                <field name="age"/>
                <field name="gender"/>
                <filter name="filter_with_gender_male" string="gender with male" domain="[('gender','=','male')]"/>
                <separator/>
                <filter name="filter_with_gender_female" string="gender with Female" domain="[('gender','=','female')]"/>
                <filter name="filter_age" string="age more 20" domain="[('age','&lt;=',20)]"/>
                <group expand="0" string="group_by">
                    <filter string="group with gender" name="group_with_gender" context="{'group_by':'gender'}"/>
                </group>

            </search>

        </field>
    </record>


    <record id="actions_hospital_appointments" model="ir.actions.act_window">
        <field name="name">hospital</field>
        <field name="res_model">hospital.appointments</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_filter_with_gender_male':1}</field>
        <field name="help" type="html">
            <div class="text-warning">
                <p>
                    not have any appointments her can make register new appointments
                </p>
            </div>
        </field>
    </record>

    <menuitem id="appointments_menu_item"
              parent="mnu_appointments_item"
              name="appointments"
              action="actions_hospital_appointments"/>
</odoo>