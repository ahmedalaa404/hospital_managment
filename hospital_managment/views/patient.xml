<odoo>

    <record id="view_hospital_patient_list" model="ir.ui.view">
        <field name="name">view of hospital patient list</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="age"/>
                <field name="color" widget="color_picker"/>
                <field name="color2" widget="color"/>
                <field name="tag_ids" widget="many2many_tags" options="{
                            'color_field':'color'}"/>
                <field name="active" invisible="1"/>
                <field name="ref"/>
                <field name="date_of_birth"/>
                <field name="gender"/>
            </tree>
        </field>
    </record>


    <record id="view_hospital_patient_form" model="ir.ui.view">
        <field name="name">view of hospital patient form</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="age"/>
                            <field name="color" widget="color_picker"/>
                            <field name="color2" widget="color"/>
                            <field name="ref"/>
                            <field name="date_of_birth"/>
                            <field name="active"/>
                            <field name="active" invisible="1"/>
                            <field name="gender"/>
                        </group>

                        <group>
                            <field name="tag_ids" widget="many2many_tags" options="{
                            'color_field':'color'}"/>
                        </group>


                    </group>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>


            </form>
        </field>
    </record>


    <record id="view_hospital_patient_search" model="ir.ui.view">
        <field name="name">view of hospital patient search</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" filter_domain="['|',('name','ilike',self),('ref','ilike',self)]"
                       string="search with name "/>
                <field name="name" string="patient name"/>
                <field name="age"/>
                <field name="gender"/>
                <filter name="filter_with_gender_male" string="gender with male" domain="[('gender','=','male')]"/>
                <separator/>
                <filter name="filter_with_gender_female" string="gender with Female"
                        domain="[('gender','=','female')]"/>
                <filter name="filter_age" string="age more 20" domain="[('age','&lt;=',20)]"/>
                <group expand="0" string="group_by">
                    <filter string="group with gender" name="group_with_gender" context="{'group_by':'gender'}"/>
                </group>

            </search>

        </field>
    </record>


    <record id="actions_hospital_patient" model="ir.actions.act_window">
        <field name="name">hospital</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_filter_with_gender_male':1}</field>
        <field name="help" type="html">
            <div class="text-warning">
                <p>
                    not have any patient her can make register new patient
                </p>
            </div>
        </field>
    </record>


    <menuitem id="patient_menu_root" name="Patient_root" parent="mnu_patient_item">
        <menuitem id="patient_menu_item"
                  name="patient_Sub_menu">
            <menuitem
                    id="patient_menu"
                    name="patient_menu"
                    string="patient"
                    action="actions_hospital_patient"/>

        </menuitem>

    </menuitem>


</odoo>